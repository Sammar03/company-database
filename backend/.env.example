# --- Secrets (required) ---
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key
# Shared secret clients must send as the X-API-Key header. Leave empty to
# disable auth (local dev); set a long random value in production.
API_KEY=
# Admin secret required to DELETE documents (X-Admin-Key). Keep it OUT of the
# frontend; share only with admins. Empty = delete open (local dev).
ADMIN_KEY=

# --- Vector store (Neon Postgres + pgvector) ---
# Copy the connection string from the Neon dashboard; keep ?sslmode=require.
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# --- Models ---
EMBED_MODEL=gemini-embedding-2
EMBED_DIMS=768
GEN_MODEL=llama-3.3-70b-versatile

# --- Chunking / retrieval ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=5

# --- Limits ---
MAX_UPLOAD_MB=25
MAX_CHUNKS_PER_DOC=1000
MAX_FILES_PER_REQUEST=20
MAX_HISTORY_TURNS=6

# --- CORS (comma-separated). Frontend dev origin by default. ---
CORS_ORIGINS=http://localhost:5173
